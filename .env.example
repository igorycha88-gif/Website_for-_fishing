# Database
POSTGRES_DB=fishing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
DATABASE_URL=postgresql+asyncpg://postgres:postgres_password@postgres:5432/fishing_db

# Redis
REDIS_URL=redis://redis:6379/0

# Auth Service
SECRET_KEY=your-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Yandex Maps API Key (required for map display)
YANDEX_MAPS_API_KEY=your_yandex_maps_api_key_here

# Frontend Build-time Variables (passed via docker-compose build args)
# These are embedded in the JS bundle during build
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=${YANDEX_MAPS_API_KEY}
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Mapbox
MAPBOX_API_KEY=your_mapbox_api_key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SMTP (Email Service)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your_email@yandex.ru
SMTP_PASSWORD=your_email_password
SMTP_FROM_EMAIL=noreply@fishing.com
SMTP_FROM_NAME=FishMap

# Traefik
TRAEFIK_DASHBOARD_CREDENTIALS=your_dashboard_credentials

# Environment
ENVIRONMENT=development

# Development email domain whitelist (only used when ENVIRONMENT=development)
# Emails ending with @test.localhost will receive test verification codes
DEV_EMAIL_DOMAIN=test.localhost

# Docker Environment (set to 'true' when running in Docker, 'false' for local dev with npm run dev)
DOCKER_ENV=false

# Vault Configuration (optional - set USE_VAULT=true to enable)
USE_VAULT=false
VAULT_ADDR=http://vault:8200
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token

# Vault AppRole credentials (get from vault-init logs)
# AUTH_VAULT_ROLE_ID=
# AUTH_VAULT_SECRET_ID=
# EMAIL_VAULT_ROLE_ID=
# EMAIL_VAULT_SECRET_ID=
# PLACES_VAULT_ROLE_ID=
# PLACES_VAULT_SECRET_ID=
# FORECAST_VAULT_ROLE_ID=
# FORECAST_VAULT_SECRET_ID=
# REPORTS_VAULT_ROLE_ID=
# REPORTS_VAULT_SECRET_ID=
# BOOKING_VAULT_ROLE_ID=
# BOOKING_VAULT_SECRET_ID=
# SHOP_VAULT_ROLE_ID=
# SHOP_VAULT_SECRET_ID=

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# Email Service API Key (min 32 characters)
EMAIL_SERVICE_API_KEY=your-secure-api-key-change-me-min-32-chars

# CSRF Protection
CSRF_ENABLED=true
CSRF_TOKEN_TTL=86400
