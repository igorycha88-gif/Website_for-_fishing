# Yandex Maps API Key
NEXT_PUBLIC_YANDEX_MAPS_API_KEY=dfb59053-0011-47fb-a6f1-a14efb9160d1

# API URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Stripe (optional)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Backend Services URLs (for middleware proxy)
AUTH_SERVICE_URL=http://auth-service:8000
PLACES_SERVICE_URL=http://places-service:8001
REPORTS_SERVICE_URL=http://reports-service:8002
BOOKING_SERVICE_URL=http://booking-service:8003
SHOP_SERVICE_URL=http://shop-service:8004
EMAIL_SERVICE_URL=http://email-service:8005
FORECAST_SERVICE_URL=http://forecast-service:8000

# Proxy Header Filtering (SEC-010)
# Comma-separated list of additional headers to allow through the proxy
# WARNING: Only add headers that are absolutely necessary. Each additional header
# increases the attack surface for header injection attacks.
# Example: PROXY_ALLOWED_HEADERS=x-custom-header,x-another-header
PROXY_ALLOWED_HEADERS=

# Docker Environment Flag
DOCKER_ENV=true
