# === FishMap Production Configuration for VPS ===
# Copy to .env.vps and fill in values.
# NEVER commit .env.vps to git!

# === Database ===
POSTGRES_DB=fishing_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_20_CHARS

# === Auth Service ===
SECRET_KEY=CHANGE_ME_RANDOM_STRING_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# === SMTP (Email Service) ===
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your_email@yandex.ru
SMTP_PASSWORD=your_smtp_app_password
SMTP_FROM_EMAIL=your_email@yandex.ru
SMTP_FROM_NAME=FishMap

# === Email Service ===
ENABLE_EMAIL_SENDING=true
EMAIL_CODE_EXPIRE_MINUTES=15
EMAIL_SERVICE_API_KEY=CHANGE_ME_RANDOM_API_KEY_MIN_32_CHARS

# === Forecast Service ===
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key

# === Frontend ===
NEXT_PUBLIC_API_URL=http://FISHMAP_DOMAIN
YANDEX_MAPS_API_KEY=your_yandex_maps_api_key
STRIPE_PUBLISHABLE_KEY=

# === Logging ===
LOG_LEVEL=INFO

# === Domain (used by deploy script for nginx config) ===
FISHMAP_DOMAIN=yourdomain.ru
